{
  "name": "droplet",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": ["packages/*"],
    "catalog": {
      "@alchemy.run/node-utils": "0.0.5",
      "@aws-sdk/credential-providers": "^3.0.0",
      "@cloudflare/containers": "^0.1.1",
      "@cloudflare/vite-plugin": "^1.13.12",
      "@cloudflare/workers-types": "^4.20250805.0",
      "@distilled.cloud/aws": "^0.24.8",
      "@distilled.cloud/axiom": "^0.24.8",
      "@distilled.cloud/cloudflare": "^0.24.8",
      "@distilled.cloud/cloudflare-rolldown-plugin": "0.10.12",
      "@distilled.cloud/cloudflare-runtime": "0.10.12",
      "@distilled.cloud/cloudflare-vite-plugin": "0.10.12",
      "@distilled.cloud/core": "^0.24.8",
      "@distilled.cloud/neon": "^0.24.8",
      "@distilled.cloud/planetscale": "^0.24.8",
      "@effect/language-service": ">=4.0.0-beta.78 || >=4.0.0",
      "@effect/platform-bun": "4.0.0-beta.83",
      "@effect/platform-node": "4.0.0-beta.83",
      "@effect/platform-node-shared": "4.0.0-beta.83",
      "@effect/sql-pg": ">=4.0.0-beta.78 || >=4.0.0",
      "@effect/vitest": ">=4.0.0-beta.78 || >=4.0.0",
      "@libsql/client": "^0.17.0",
      "@opentui/core": "latest",
      "@opentui/solid": "latest",
      "@smithy/node-config-provider": "^4.0.0",
      "@smithy/shared-ini-file-loader": "^4.3.4",
      "@smithy/types": "^4.8.1",
      "@types/aws-lambda": "^8.10.152",
      "@types/bun": "latest",
      "@types/node": "latest",
      "@typescript/native-preview": "latest",
      "ai": "^6.0.62",
      "alchemy": "file:./repos/alchemy/packages/alchemy",
      "aws4fetch": "^1.0.20",
      "better-auth": "^1.6.2",
      "drizzle-kit": ">=1.0.0-rc.1",
      "drizzle-orm": ">=1.0.0-rc.1",
      "effect": "4.0.0-beta.83",
      "fast-xml-parser": "^5.3.4",
      "rolldown": "1.0.1",
      "solid-js": "latest",
      "sonda": "^0.11.1",
      "typescript": "^6.0.3",
      "uuid": "^14.0.0",
      "vite": "^8.0.7",
      "web-tree-sitter": "0.25.10",
      "ws": "^8.20.0",
      "yaml": "^2.0.0"
    }
  },
  "scripts": {
    "check": "bun run build && bun run --cwd packages/droplet check && bun run --cwd packages/auth-app check:types && bun run --cwd packages/tasks-app check:types && bun run --cwd packages/chat-app check:types",
    "test": "bun run build && bun run --cwd packages/auth-app test:run && bun run --cwd packages/tasks-app test:run && bun run --cwd packages/chat-app test:run",
    "build": "bun run --cwd packages/droplet build",
    "promote:auth": "bun ./scripts/promote-auth-template.ts",
    "promote:tasks": "bun ./scripts/promote-tasks-template.ts",
    "promote:chat": "bun ./scripts/promote-chat-template.ts",
    "check:auth-template": "bun run promote:auth && git diff --exit-code -- packages/droplet/templates/auth",
    "check:tasks-template": "bun run promote:tasks && git diff --exit-code -- packages/droplet/templates/tasks",
    "check:chat-template": "bun run promote:chat && git diff --exit-code -- packages/droplet/templates/chat",
    "publish:dry-run": "bun run --cwd packages/droplet publish:dry-run",
    "deploy:auth": "bun run --cwd packages/auth-app deploy",
    "destroy:auth": "bun run --cwd packages/auth-app destroy",
    "deploy:tasks": "bun run --cwd packages/tasks-app deploy",
    "destroy:tasks": "bun run --cwd packages/tasks-app destroy",
    "deploy:chat": "bun run --cwd packages/chat-app deploy",
    "destroy:chat": "bun run --cwd packages/chat-app destroy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
