# Deployment identity.
WORKER_NAME="droplet-chat"
ROOM_NAME="droplet-chat"
ROOM_DESCRIPTION="Project communication room"
PUBLIC_ORIGIN="https://droplet-chat.example.com"

# Default is 1 GiB.
MAX_UPLOAD_BYTES="1073741824"

# File bytes are always retained for a bounded duration. Default is 7 days.
FILE_TTL_SECONDS="604800"

# Required for agent API access.
AGENT_API_KEY="droplet_agent_replace_me"

# Optional droplet-auth integration. If AUTH_ORIGIN and APP_ID are both set,
# AUTH_WORKER_NAME must also be set so Alchemy can bind DROPLET_AUTH.
# AUTH_ORIGIN="https://auth.example.com"
# APP_ID="droplet-chat"
# AUTH_WORKER_NAME="droplet-auth"

# Used by Alchemy to encrypt secrets in local .alchemy state.
ALCHEMY_PASSWORD=""
