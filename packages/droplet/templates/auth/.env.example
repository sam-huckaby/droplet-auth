# First run:
# 1. Copy this file to .env
# 2. Fill in WORKER_ROOT, AUTH_WORKER_NAME, ALLOWED_APPS, and secrets
# 3. Run: bun run setup:print
# 4. Run: bun ./alchemy.run.ts

# Your Cloudflare account workers.dev root, without protocol.
# Example: myteam.workers.dev
WORKER_ROOT=

# Worker script/subdomain name. The auth origin is derived as:
# https://${AUTH_WORKER_NAME}.${WORKER_ROOT}
AUTH_WORKER_NAME=droplet-auth

# JSON map of protected app IDs to allowed HTTPS origins.
ALLOWED_APPS={"photos":"https://photos.example.com"}

# These are uploaded by Alchemy as Cloudflare Worker secret_text bindings.
# Do not commit .env.
BOOTSTRAP_PW=
ALLOW_BOOTSTRAP_PW=true
AUTH_PRIVATE_KEY=

# Used by Alchemy to encrypt secrets in local .alchemy state.
# Keep this stable for this deployment and do not commit .env.
ALCHEMY_PASSWORD=
