{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "WebWorker"
    ],
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": [
      "@cloudflare/workers-types/2023-07-01",
      "node",
      "bun"
    ],
    "allowImportingTsExtensions": true
  },
  "include": [
    "alchemy.run.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "examples/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts"
  ]
}
