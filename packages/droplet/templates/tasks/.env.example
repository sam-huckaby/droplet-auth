# First run:
# 1. Copy this file to .env
# 2. Fill in PROJECT_NAME and WORKER_NAME
# 3. Run: bun run deploy

PROJECT_NAME="My Project"
WORKER_NAME="my-project-tasks"

# Optional auth configuration
AUTH_ORIGIN=https://your-auth-worker.your-account.workers.dev
APP_ID="the-app-id-you-use-in-the-auth-map"
AUTH_WORKER_NAME="the name of your auth worker"

# Used by Alchemy to encrypt secrets in local .alchemy state.
# Keep this stable for this deployment and do not commit .env.
ALCHEMY_PASSWORD=
