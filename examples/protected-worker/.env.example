# Auth Worker origin from the main Droplet Auth deployment.
AUTH_ORIGIN=https://droplet-auth.example.workers.dev

# Auth Worker script name in Cloudflare. This is used for a service binding.
AUTH_WORKER_NAME=droplet-auth

# Must match a key in the auth service ALLOWED_APPS JSON map.
APP_ID=photos

# Optional Worker script/subdomain name for this protected test app.
PROTECTED_WORKER_NAME=photos-protected
